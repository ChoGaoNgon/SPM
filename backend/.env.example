# ===== Database chính (MySQL) =====
SPRING_DATASOURCE_URL=jdbc:mysql://<host>:3306/<database>
SPRING_DATASOURCE_USERNAME=<db_username>
SPRING_DATASOURCE_PASSWORD=<db_password>
SERVER_PORT=8081

# ===== DB3 (PostgreSQL - read-only) =====
DB3_ENABLED=true
DB3_URL=jdbc:postgresql://<host>:<port>/<database>
DB3_USERNAME=<db3_username>
DB3_PASSWORD=<db3_password>

# ===== DB2 (MySQL) =====
DB2_ENABLED=true
DB2_URL=jdbc:mysql://<host>:3306/<database>?zeroDateTimeBehavior=convertToNull
DB2_USERNAME=<db2_username>
DB2_PASSWORD=<db2_password>

# ===== JWT =====
# Chuỗi bí mật để ký JWT (tối thiểu 32 ký tự ngẫu nhiên)
JWT_SECRET=<random_secret_min_32_chars>

# ===== Đường dẫn lưu trữ =====
FILE_UPLOAD_DIR=/path/to/uploads
BACKEND_LOG_PATH=/path/to/logs/backend
APP_NAME=quanlycodien

# ===== Service nội bộ =====
WEB_SOCKET_SERVER=http://<host>:4000/ws
WINDOW_SERVER=http://<host>:5001

# HRM API để đồng bộ lịch làm việc
HRM_API=http://<host>:3000/api

# ===== Mail =====
MAIL_DEFAULT=<email>
MAIL_DEFAULT_PASSWORD=<email_app_password>

# ===== Redis =====
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=<redis_password>

# ===== CORS =====
# Danh sách origin cho phép, phân tách bằng dấu phẩy
CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:3000
